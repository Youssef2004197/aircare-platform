# ====================================================================
# AirCare+ Global GitIgnore Configuration
# ====================================================================

# Operating System Files
Thumbs.db
Desktop.ini
.DS_Store

# IDEs and Code Editors
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# Python Dependencies & Virtual Environments
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
env/
.env
*.env

# Node.js Frontend Dependencies & Builds
node_modules/
/frontend/dist
/frontend/build
.npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Docker & Database local caches
docker/postgres_data/
*.db
*.sqlite3